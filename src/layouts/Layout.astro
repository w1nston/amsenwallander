---
import '../styles/baseline.css';
import '../styles/colors.css';
import '../styles/vars.css';
import '../styles/globals.css';
import NavBar from '../features/navigation/NavBar.astro';
import ThemeToggle from '../features/navigation/ThemeToggle.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<script is:inline>
			(function() {
				var theme = localStorage.getItem('theme');
				if (theme === 'dark' || theme === 'light') {
					document.documentElement.setAttribute('data-theme', theme);
				}
			})();
		</script>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Roboto&display=optional" rel="stylesheet">
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>Amsen-Wallander</title>
	</head>
	<body>
		<NavBar />
    <div class="spacing"></div>
    <slot />
		<ThemeToggle variant="fab" />
	</body>
</html>

<style>
  .spacing {
      padding-top: 5rem;
  }

  body {
      padding-bottom: 3.75rem;
  }

  @media (min-width: 500px) {
      body {
          padding-bottom: 0;
      }
  }

	.no-scroll {
		overflow: hidden;
	}
</style>
