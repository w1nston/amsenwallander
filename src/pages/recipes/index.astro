---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import RecipeCard from '../../features/recipes/RecipeCard.astro';
import FilterButton from '../../features/recipes/FilterButton.astro';
import RecipeFilterDialog from '../../features/recipes/RecipeFilterDialog.astro';

let allRecipes = await getCollection('recipes');

let uniqueTags = allRecipes.reduce((acc, recipe) => {
  recipe.data.tags.forEach((tag) => {
    acc.add(tag);
  });

  return acc;
}, new Set());

let availableTags = Array.from(uniqueTags);

function alphabeticallyByTitle(a: any, b: any) {
  return a.data.title.localeCompare(b.data.title, 'sv');
}
---

<Layout>
  <section>
    <h1>Recept</h1>
    <ul id="recipe-list">
      {allRecipes
        .sort(alphabeticallyByTitle)
        .map((recipe) => (
          <li data-tags={recipe.data.tags.join(';')} data-title={recipe.data.title.toLowerCase()}>
            <RecipeCard slug={recipe.data.slug} title={recipe.data.title} tags={recipe.data.tags} />
          </li>
        ))}
    </ul>
  </section>

  <FilterButton id="filter-button" />
  <RecipeFilterDialog id="filter-dialog" availableTags={availableTags} />
</Layout>

<script>
  import { initRecipeFilter } from '../../features/recipes/recipe-filter';

  initRecipeFilter({
    fabId: 'filter-button',
    dialogId: 'filter-dialog',
    recipeListId: 'recipe-list',
  });
</script>

<style>
    section {
        padding: 1rem 1rem 3.75rem 1rem;
    }

    h1 {
        margin-top: 0;
    }

    ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    ul > li {
        margin: var(--spacing-md) 0;
    }

    ul > li.hidden {
        display: none;
    }
</style>
