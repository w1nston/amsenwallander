---
import ThemeToggle from './ThemeToggle.astro';
---

<header>
	<nav>
		<a href="/">
			<img src="/icon/aw-logo.png" width="192" height="191" alt="Logo" />
		</a>
		<a href="/recipes">Recept</a>
        <a href="/preparations">Förberedelser</a>
		<ThemeToggle variant="header" />
	</nav>
</header>

<style>
	header {
		background-color: var(--surface-color);
		color: var(--surface-text-color);
		padding: 1rem;
		box-shadow: 0px 2px 4px -1px rgba(0,0,0,0.2),0px 4px 5px 0px rgba(0,0,0,0.14),0px 1px 10px 0px rgba(0,0,0,0.12);
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 10;
		height: 5rem;
	}

	header > nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--spacing-lg);
	}

	header > nav > a {
		display: flex;
		color: var(--surface-text-color);
		text-decoration: none;
		font-size: 24px;
	}

	a > img {
		width: 48px;
		height: 48px;
		border-radius: 50%;
	}

	:global(html[data-theme="dark"]) a > img {
		filter: invert(0.8) hue-rotate(180deg) sepia(0.3) saturate(2) brightness(1.1);
	}

	@media (prefers-color-scheme: dark) {
		:global(html:not([data-theme])) a > img {
			filter: invert(0.8) hue-rotate(180deg) sepia(0.3) saturate(2) brightness(1.1);
		}
	}

</style>
