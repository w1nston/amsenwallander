---
// ...
---

<header>
	<nav>
		<a href="/">
			<img src="/icon/aw-logo.png" width="192" height="191" alt="Logo" />
		</a>
		<a href="/recipes">Recept</a>
        <a href="/preparations">Förberedelser</a>
		<button class="theme-toggle" aria-label="Byt tema" type="button">
			<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="12" cy="12" r="5"/>
				<line x1="12" y1="1" x2="12" y2="3"/>
				<line x1="12" y1="21" x2="12" y2="23"/>
				<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
				<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
				<line x1="1" y1="12" x2="3" y2="12"/>
				<line x1="21" y1="12" x2="23" y2="12"/>
				<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
				<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
			</svg>
			<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
			</svg>
		</button>
	</nav>
</header>

<style>
	header {
		background-color: var(--surface-color);
		color: var(--surface-text-color);
		padding: 1rem;
		box-shadow: 0px 2px 4px -1px rgba(0,0,0,0.2),0px 4px 5px 0px rgba(0,0,0,0.14),0px 1px 10px 0px rgba(0,0,0,0.12);
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 10;
		height: 5rem;
	}

	header > nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--spacing-lg);
	}

	header > nav > a {
		display: flex;
		color: var(--surface-text-color);
		text-decoration: none;
		font-size: 24px;
	}

	a > img {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		mix-blend-mode: multiply;
	}

	.theme-toggle {
		background: none;
		border: none;
		color: var(--surface-text-color);
		cursor: pointer;
		padding: var(--spacing-xs);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-left: auto;
	}

	.icon-sun { display: none; }
	.icon-moon { display: block; }

	:global(html[data-theme="dark"]) .icon-sun { display: block; }
	:global(html[data-theme="dark"]) .icon-moon { display: none; }

	@media (prefers-color-scheme: dark) {
		:global(html:not([data-theme])) .icon-sun { display: block; }
		:global(html:not([data-theme])) .icon-moon { display: none; }
	}
</style>

<script>
	function getEffectiveTheme(): 'light' | 'dark' {
		const explicit = document.documentElement.getAttribute('data-theme');
		if (explicit === 'dark' || explicit === 'light') return explicit;
		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	}

	document.querySelector('.theme-toggle')?.addEventListener('click', () => {
		const current = getEffectiveTheme();
		const next = current === 'dark' ? 'light' : 'dark';
		document.documentElement.setAttribute('data-theme', next);
		localStorage.setItem('theme', next);
	});
</script>
